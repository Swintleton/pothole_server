@startuml
!define RECTANGLE class

RECTANGLE "Login Screen" as Login {
  - Username field
  - Password field
  - Login button
}

RECTANGLE "Registration Screen" as Registration {
  - Username, Name, Password fields
  - Confirm Password field
  - Email and Phone fields
  - Register button
}

RECTANGLE "Home Screen" as Home {
  - "Welcome" text
  - "Pothole Detector" title
  - Navigation buttons to Map/Camera
}

RECTANGLE "Map Screen" as Map {
  - Google Map
  - Pothole markers
  - Long-press to add a new pothole
  - Role-based editing/deletion
}

RECTANGLE "Map Confirmation Dialog" as MapConfirm {
  - Pothole detection confirmation
  - "Yes" / "No" buttons
  - Cancel button
}

RECTANGLE "Camera Screen" as Camera {
  - Camera preview
  - Capture and upload frames
  - Frame processing with AI
}

RECTANGLE "Camera Detection Confirmation Dialog" as CameraConfirm {
  - Display detected pothole by AI
  - "Confirm" or "Cancel" detection
}

RECTANGLE "Pothole Edit Dialog" as Edit {
  - Pothole details
  - Save, Cancel, or Delete
}

RECTANGLE "Logout Logic" as Logout {
  - Automatic logout on invalid token detection
  - Manual logout option
}

Login --> Home : Login success
Login --> Registration : "Register button" 
Registration --> Login : Back to Login or Registration success
Home --> Map : Navigate to map
Map --> Home : Navigate to home
Home --> Camera : Navigate to camera
Camera --> Home : Navigate to home
Home --> Logout : "Logout button"
Map --> MapConfirm : "On marker tap"
Map --> Edit : "On marker long-press"
MapConfirm --> Map : "Confirm or Cancel"
Camera --> CameraConfirm : "AI detects pothole, prompts user"
CameraConfirm --> Camera : "Confirm or Cancel detection"
Edit --> Map : "Save, delete, or cancel and return to map"
CameraConfirm --> Logout : "Invalid token detected"
MapConfirm --> Logout : "Invalid token detected"
Map --> Camera : Navigate to camera
Camera --> Map : Navigate to map
@enduml
